{
  "name": "@emulators/cloudflare",
  "version": "0.6.0",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./worker": {
      "import": "./dist/worker.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "gen:console": "node scripts/gen-console.mjs",
    "build": "tsup --clean",
    "dev": "tsup --watch",
    "clean": "rm -rf dist .turbo",
    "type-check": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@emulators/core": "workspace:*",
    "@emulators/github": "workspace:*",
    "@emulators/vercel": "workspace:*",
    "@emulators/google": "workspace:*",
    "@emulators/okta": "workspace:*",
    "@emulators/microsoft": "workspace:*",
    "@emulators/mcp": "workspace:*",
    "@emulators/spotify": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5.7"
  }
}
