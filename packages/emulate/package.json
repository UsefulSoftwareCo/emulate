{
  "name": "@executor-js/emulate",
  "version": "0.13.3",
  "description": "Local drop-in replacement services for CI and no-network sandboxes",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/api.js",
      "types": "./dist/api.d.ts"
    },
    "./cli": {
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/api.js",
  "types": "./dist/api.d.ts",
  "homepage": "https://emulators.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/vercel-labs/emulate.git",
    "directory": "packages/emulate"
  },
  "bugs": {
    "url": "https://github.com/vercel-labs/emulate/issues"
  },
  "keywords": [
    "emulator",
    "mock",
    "api",
    "vercel",
    "github",
    "google",
    "oauth",
    "testing",
    "ci",
    "local-development"
  ],
  "files": [
    "dist"
  ],
  "bin": {
    "emulate": "./dist/index.js"
  },
  "scripts": {
    "prepack": "cp ../../README.md .",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo",
    "type-check": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1031.0",
    "@aws-sdk/client-sqs": "^3.1075.0",
    "@azure/msal-node": "^5.3.0",
    "@clerk/backend": "^3.8.4",
    "@octokit/rest": "^22.0.1",
    "@okta/okta-auth-js": "^8.0.1",
    "@slack/web-api": "^7.16.0",
    "@vercel/sdk": "^1.28.4",
    "@workos-inc/node": "^8.13.0",
    "atlas-api-client": "^0.3.0",
    "autumn-js": "^1.2.8",
    "commander": "^14",
    "googleapis": "^173.0.0",
    "graphql": "^16.9.0",
    "graphql-request": "^7.4.0",
    "openid-client": "^6.8.4",
    "picocolors": "^1.1.1",
    "resend": "^6.16.0",
    "spotify-web-api-node": "^5.0.2",
    "stripe": "^22.3.0",
    "twitter-api-v2": "^1.29.0",
    "yaml": "^2"
  },
  "devDependencies": {
    "@emulators/core": "workspace:*",
    "@emulators/github": "workspace:*",
    "@emulators/gitlab": "workspace:*",
    "@emulators/mcp": "workspace:*",
    "@emulators/apple": "workspace:*",
    "@emulators/microsoft": "workspace:*",
    "@emulators/okta": "workspace:*",
    "@emulators/aws": "workspace:*",
    "@emulators/google": "workspace:*",
    "@emulators/mongoatlas": "workspace:*",
    "@emulators/slack": "workspace:*",
    "@emulators/vercel": "workspace:*",
    "@emulators/resend": "workspace:*",
    "@emulators/stripe": "workspace:*",
    "@emulators/clerk": "workspace:*",
    "@emulators/posthog": "workspace:*",
    "@emulators/spotify": "workspace:*",
    "@emulators/x": "workspace:*",
    "tsup": "^8",
    "typescript": "^5.7",
    "@emulators/autumn": "workspace:*",
    "@emulators/workos": "workspace:*"
  }
}
